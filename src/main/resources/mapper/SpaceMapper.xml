<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lumenglover.yuemupicturebackend.mapper.SpaceMapper">

    <resultMap id="BaseResultMap" type="com.lumenglover.yuemupicturebackend.model.entity.Space">
        <id property="id" column="id" jdbcType="BIGINT"/>
        <result property="spaceName" column="spaceName" jdbcType="VARCHAR"/>
        <result property="spaceLevel" column="spaceLevel" jdbcType="INTEGER"/>
        <result property="maxSize" column="maxSize" jdbcType="BIGINT"/>
        <result property="maxCount" column="maxCount" jdbcType="BIGINT"/>
        <result property="totalSize" column="totalSize" jdbcType="BIGINT"/>
        <result property="totalCount" column="totalCount" jdbcType="BIGINT"/>
        <result property="spaceDesc" column="spaceDesc" jdbcType="VARCHAR"/>
        <result property="spaceCover" column="spaceCover" jdbcType="VARCHAR"/>
        <result property="userId" column="userId" jdbcType="BIGINT"/>
        <result property="spaceType" column="spaceType" jdbcType="INTEGER"/>
        <result property="createTime" column="createTime" jdbcType="TIMESTAMP"/>
        <result property="editTime" column="editTime" jdbcType="TIMESTAMP"/>
        <result property="updateTime" column="updateTime" jdbcType="TIMESTAMP"/>
        <result property="isDelete" column="isDelete" jdbcType="TINYINT"/>
        <result property="isRecommended" column="isRecommended" jdbcType="TINYINT"/>
        <result property="maxStorage" column="maxStorage" jdbcType="INTEGER"/>
        <result property="usedStorage" column="usedStorage" jdbcType="INTEGER"/>
    </resultMap>

    <sql id="Base_Column_List">
        id,spaceName,spaceLevel,spaceType,
        maxSize,maxCount,totalSize,
        totalCount,spaceDesc,spaceCover,
        userId,createTime,editTime,
        updateTime,isDelete,isRecommended,
        maxStorage,usedStorage
    </sql>

    <!-- 查询已删除的空间（绕过逻辑删除） -->
    <select id="selectDeletedSpacesByUpdateTime" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM space
        WHERE isDelete = 1
        AND updateTime >= #{updateTime}
    </select>

    <!-- 查询所有已删除的空间（绕过逻辑删除） -->
    <select id="selectAllDeletedSpaces" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM space
        WHERE isDelete = 1
    </select>

</mapper>
