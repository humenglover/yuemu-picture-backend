<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lumenglover.yuemupicturebackend.mapper.AiChatMapper">

    <resultMap id="BaseResultMap" type="com.lumenglover.yuemupicturebackend.model.entity.AiChat">
        <id property="id" column="id" jdbcType="BIGINT"/>
        <result property="userId" column="userId" jdbcType="BIGINT"/>
        <result property="content" column="content" jdbcType="VARCHAR"/>
        <result property="role" column="role" jdbcType="VARCHAR"/>
        <result property="createTime" column="createTime" jdbcType="TIMESTAMP"/>
        <result property="isDeleted" column="isDeleted" jdbcType="TINYINT"/>
        <result property="sessionId" column="sessionId" jdbcType="BIGINT"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, userId, content, role, createTime, isDeleted, sessionId
    </sql>

    <!-- 修改selectList查询，使用ResultMap -->
    <select id="selectList" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM aichat
        WHERE isDeleted = 0
        <if test="ew != null">
            AND ${ew.sqlSegment}
        </if>
    </select>

    <insert id="batchInsert" parameterType="java.util.List">
        INSERT INTO aichat (userId, content, role, createTime, isDeleted, sessionId)
        VALUES
        <foreach collection="list" item="item" separator=",">
            (#{item.userId}, #{item.content}, #{item.role}, #{item.createTime}, #{item.isDeleted}, #{item.sessionId})
        </foreach>
    </insert>
</mapper>
