# ============================================
# 悦木图片管理系统 - 环境变量配置模板
# ============================================
#
# 🔰 文件结构（每个环境一个独立文件，自包含所有变量）：
#
#   .env.dev      ← 开发环境（本地 MySQL/Redis/Qdrant 地址）
#   .env.prod     ← 生产环境（Docker 容器地址 + 强密码）
#
#   启动时根据 spring.profiles.active 自动加载对应文件
#
# 🚀 使用方式：
#   - 本地开发：cp .env.example .env.dev，编辑填入真实值，启动即可
#   - Docker：docker compose --env-file .env.prod up
#
# ⚠️ .env.* 全部 gitignore，不会提交到 Git
# ⚠️ 此模板可安全提交到 GitHub
#
# 📋 快速开始：
#   1. cp .env.example .env.dev
#   2. 编辑 .env.dev 填入开发环境真实值
#   3. 启动项目（IDE 或 mvn spring-boot:run）
# ============================================

# ============================================
# 通用
# ============================================
COMMON_DEFAULT_PASSWORD=your_default_password
COMMON_DEFAULT_SALT=your_salt

# ============================================
# MySQL
# ============================================
MYSQL_PASSWORD=your_mysql_password

# ============================================
# Redis
# ============================================
REDIS_PASSWORD=

# ============================================
# MeiliSearch
# ============================================
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=your_meilisearch_key

# ============================================
# Qdrant
# ============================================
QDRANT_HOST=localhost
QDRANT_PORT=6334

# ============================================
# 邮箱（QQ邮箱 SMTP）
# ============================================
MAIL_FROM=your_email@qq.com
MAIL_PASSWORD=your_smtp_authorization_code
MAIL_ADMIN=your_admin_email@qq.com

# ============================================
# Knife4j 接口文档
# ============================================
KNIFE4J_USERNAME=admin
KNIFE4J_PASSWORD=your_knife4j_password

# ============================================
# 腾讯云 COS
# ============================================
COS_HOST=https://your-bucket.cos.ap-guangzhou.myqcloud.com
COS_SECRET_ID=your_secret_id
COS_SECRET_KEY=your_secret_key
COS_REGION=ap-guangzhou
COS_BUCKET=your-bucket-name
COS_ADMIN_EMAIL=your_admin_email@qq.com
COS_CUSTOM_DOMAIN=https://cdn.your-domain.com

# ============================================
# 阿里云 AI
# ============================================
ALIYUN_AI_API_KEY=your_aliyun_ai_key

# ============================================
# 微信
# ============================================
WX_MP_TOKEN=your_wechat_token

# ============================================
# Pexels
# ============================================
PEXELS_API_KEY=your_pexels_key
PEXELS_BOT_PASSWORD=your_bot_password

# ============================================
# Python RAG 服务
# ============================================
RAG_PYTHON_SERVICE_BASE_URL=http://127.0.0.1:8001
